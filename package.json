{
  "name": "jellytunes",
  "version": "0.5.0",
  "description": "Sincronizador de música Jellyfin → dispositivos MP3/FLAC",
  "homepage": "https://github.com/orainlabs/jellytunes",
  "main": "dist/main/index.js",
  "author": {
    "name": "Orain Labs",
    "email": "hi@orainlabs.dev"
  },
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "electron-vite build && electron-vite dev",
    "build": "electron-vite build",
    "build:dev": "VITE_DEV_BUILD=true NODE_ENV=development electron-vite build",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run build",
    "lint": "eslint src tests",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "preview": "electron-vite preview",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "package:dir": "npm run build && electron-builder --dir",
    "package:dev": "npm run build:dev && electron-builder --dir",
    "test:bdd": "pnpm build && TS_NODE_PROJECT=tests/bdd/tsconfig.json cucumber-js --config tests/bdd/cucumber.js",
    "test:bdd:dev": "pnpm build && TS_NODE_PROJECT=tests/bdd/tsconfig.json cucumber-js --config tests/bdd/cucumber.js --profile dev",
    "test:bdd:ci": "pnpm build && TS_NODE_PROJECT=tests/bdd/tsconfig.json cucumber-js --config tests/bdd/cucumber.js --profile ci",
    "test:bdd:report": "open tests/bdd/reports/cucumber-report.html",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:renderer": "vitest run --config vitest.renderer.config.ts",
    "test": "pnpm run test:unit",
    "postinstall": "electron-builder install-app-deps",
    "build-icon": "node scripts/build-icon.mjs",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "better-sqlite3": "^12.8.0",
    "electron-log": "^5.2.4",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "usb-detection": "^4.14.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.0.1",
    "@cucumber/pretty-formatter": "^1.0.1",
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/drivelist": "^6.4.4",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.3.1",
    "electron-builder": "^26.15.7",
    "electron-vite": "^2.3.0",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-security": "^4.0.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.4.3",
    "playwright": "^1.40.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.jellytunes.app",
    "productName": "JellyTunes",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!**/node_modules/better-sqlite3/deps/**",
      "!**/node_modules/better-sqlite3/src/**",
      "!**/node_modules/better-sqlite3/gyp/**",
      "!**/node_modules/better-sqlite3/**/*.c",
      "!**/node_modules/better-sqlite3/**/*.h"
    ],
    "asarUnpack": [
      "**/better-sqlite3/build/Release/*.node",
      "**/node_modules/@ffmpeg-installer/**"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns",
      "compression": "maximum",
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,css,md}": [
      "prettier --write"
    ]
  }
}
