#!/usr/bin/env sh
# Automatically typecheck, lint and format on commit

# Run TypeScript type check first
echo "Running TypeScript typecheck..."
pnpm run typecheck

if [ $? -ne 0 ]; then
  echo "TypeScript typecheck failed. Please fix the errors before committing."
  exit 1
fi

echo "Typecheck passed!"

# Run format check
echo "Checking formatting with Prettier..."
pnpm run format:check

# If format fails, abort commit
if [ $? -ne 0 ]; then
  echo "Prettier format check failed. Please run 'pnpm format' to fix formatting."
  exit 1
fi

echo "Formatting passed!"

# Run lint check
echo "Running ESLint..."
pnpm run lint

# If lint fails, abort commit
if [ $? -ne 0 ]; then
  echo "ESLint failed. Please fix the errors before committing."
  exit 1
fi

echo "Linting passed!"